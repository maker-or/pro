meta {
  name: Validate token via API
  type: http
  seq: 1
}

get {
  url: http://localhost:3000/api/v1/chat/completions
  body: none
  auth: none
}

headers {
  authorization: Bearer {{apiToken}}
}

tests {
  test("not blocked by WorkOS redirect", function () {
    expect(res.status).to.not.equal(307);
  });
  
  test("returns backend validation status", function () {
    expect([200, 401, 503]).to.include(res.status);
  });
}

settings {
  encodeUrl: false
  timeout: 0
  followRedirects: false
}
